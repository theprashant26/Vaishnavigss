# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In production, every variable below should have a real value.
# In dev, only RAZORPAY_* matter (everything else has dev defaults).

# --------------------------------------------------------------------------
# Django
# --------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=
# vaishnavi.settings.dev for local, vaishnavi.settings.prod for production
DJANGO_SETTINGS_MODULE=vaishnavi.settings.prod
# Comma-separated. Add www. variant if used.
ALLOWED_HOSTS=vaishnavigss.com,www.vaishnavigss.com
SITE_DOMAIN=https://vaishnavigss.com

# --------------------------------------------------------------------------
# Database (production — PostgreSQL)
# --------------------------------------------------------------------------
DB_NAME=vaishnavi_prod
DB_USER=vaishnavi
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# --------------------------------------------------------------------------
# Email (Postmark, AWS SES, or any SMTP provider)
# --------------------------------------------------------------------------
EMAIL_HOST=smtp.postmarkapp.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Vaishnavi Gaushala <hello@vaishnavigss.com>
SERVER_EMAIL=errors@vaishnavigss.com
ADMIN_EMAIL=admin@vaishnavigss.com

# --------------------------------------------------------------------------
# SMS (MSG91 — required for India OTPs; needs DLT registration)
# --------------------------------------------------------------------------
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# --------------------------------------------------------------------------
# Razorpay (test keys for staging, live keys for production)
# Get from dashboard.razorpay.com -> Settings -> API Keys
# Webhook secret: Settings -> Webhooks -> your webhook
# --------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------------------------------
# HSTS — start at 60 for the first week so we can roll back. Bump to
# 31536000 (1 year) once the site has run cleanly under HTTPS for ~24h.
# --------------------------------------------------------------------------
SECURE_HSTS_SECONDS=60

# --------------------------------------------------------------------------
# Optional: media on attached volume
# --------------------------------------------------------------------------
# MEDIA_ROOT=/mnt/media
